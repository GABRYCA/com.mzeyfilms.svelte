BODY_SIZE_LIMIT=15728640
ORIGIN=https://yourdomain.com
PRIVATE_LOGIN_PASSWORD=PasswordForAdminPanel    # Available at: https://yourdomain.com/admin
PRIVATE_LOGIN_USERNAME=yourusername
PRIVATE_POCKETBASE_EMAIL=PocketbaseAdminEmail@emaildomain.com
PRIVATE_POCKETBASE_PASSWORD=PocketbaseAdminPassword
PUBLIC_POCKETBASE_URL=https://DomainOrAddressToPocketbaseInstance.com
PUBLIC_POCKETBASE_URL_IMG_API=https://DomainOrAddressToPocketbaseInstance.com/api/files/
PUBLIC_IMAGE_PROXY_URL=https://DomainOrAddressToNextImageTransfortmation.com/image/     # Info: https://github.com/coollabsio/next-image-transformation

# Optional: YouTube animated preview generation on VPS (yt-dlp bot checks)
# Datacenter IPs are often blocked; non-web clients are tried first automatically.
# If downloads still fail with "Sign in to confirm you're not a bot", export Netscape
# cookies from a browser logged into YouTube and provide them here:
#   https://github.com/yt-dlp/yt-dlp/wiki/Extractors#exporting-youtube-cookies
# YTDLP_COOKIES_FILE=/run/secrets/youtube-cookies.txt
# YTDLP_COOKIES=            # alternative: paste full cookies.txt content (use \n for newlines)
# YTDLP_PROXY=              # optional http:// or socks5:// proxy
# YTDLP_EXTRA_ARGS=         # optional extra yt-dlp flags (space-separated)
